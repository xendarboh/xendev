IMAGE_BASE=ubuntu:24.04

# optional installations; 1=enable, 0=disable
INSTALL_AIDER=0
INSTALL_BROWSER_BRAVE=0
INSTALL_BROWSER_CHROMIUM=0
INSTALL_CIRCOM=0
INSTALL_CLAUDECODE=0
INSTALL_CYPRESS_DEPS=0
INSTALL_DEVOPS=0
INSTALL_DOCS=0
INSTALL_LLVM=0
INSTALL_NIX=0
INSTALL_NOIR=0
INSTALL_OPENCODE=0
INSTALL_PB=0
INSTALL_PLATFORMIO=0
INSTALL_TAURI=0
INSTALL_TOMB=0

# choose one:
INSTALL_NEOVIM_FROM_PPA_STABLE=0
INSTALL_NEOVIM_FROM_PPA_UNSTABLE=0
INSTALL_NEOVIM_FROM_SRC=1

# versions
VERSION_AZTEC=4.0.0-devnet.2-patch.1
VERSION_FISH=release-4
VERSION_KPCLI=4.1.3
VERSION_LLVM=21
VERSION_NEOVIM_FROM_SRC=stable
VERSION_NODE=LTS
VERSION_OHMYOPENCODE=3.11.2
VERSION_TOMB=v2.13

# version examples
# VERSION_NEOVIM_FROM_SRC=release-0.11
# VERSION_NEOVIM_FROM_SRC=stable
# VERSION_NODE=LATEST
# VERSION_NODE=v24.12.0

# options
OPTIONS_NVIM_APPNAME=nvim-lazyvim
OPTIONS_OHMYOPENCODE=--claude=yes --gemini=yes --copilot=yes --openai=yes --opencode-zen=yes
#   --claude=<yes|no|max20> --gemini=<yes|no> --copilot=<yes|no> [--openai=<yes|no>] [--opencode-zen=<yes|no>] [--zai-coding-plan=<yes|no>]
OPTIONS_THEME=base24-gruvbox-dark-hard
#   base24-gruvbox-dark-hard, base24-tokyo-night-dark (have native nvim plugins) | any `tinty list` scheme

# Optional: Docker Model Runner (docker-compose.yml --profile models)
MODELS_PRIMARY=ai/smollm2
#   See https://hub.docker.com/u/ai or https://huggingface.co/models?filter=transformers&sort=trending
#   Example models that work with 8GB GPU RAM:
#     hf.co/unsloth/Qwen3.5-9B-GGUF:Q4_K_M
#     ai/qwen3:8B-Q4_K_M
MODELS_WEBUI_PORT=12444

# vim: ft=sh
