export GOPATH=~/go
export PNPM_HOME=~/.pnpm

export PATH=~/.local/bin:${PATH}
export PATH=~/.go/bin:${GOPATH}/bin:${PATH}
export PATH=${PNPM_HOME}:${PATH}
export PATH=~/.yarn/bin:${PATH}
export PATH=./node_modules/.bin:${PATH}
export PATH=~/.aztec/bin:${PATH}
export PATH=~/.aztec/current/bin:~/.aztec/current/node_modules/.bin:${PATH}
export PATH=${XNDV_DIR}/bin:${PATH}

export GPG_TTY=$(tty)

export TERM=screen-256color

export EDITOR=/usr/bin/vim
export VISUAL=/usr/bin/vim

# enable vi key bindings
# set -o vi

# ~20170710 fix neovim black and white bug
# https://github.com/neovim/neovim/issues/6982#issuecomment-313879899
export COLORTERM=truecolor

if [ -f ~/.bash_prompt ]; then
  . ~/.bash_prompt
fi

command -v buf >/dev/null && eval "$(buf completion bash)"

eval "$(fnm completions --shell bash)"

# ~INSTALL_NOIR
if [ -d ${NARGO_HOME} ]; then
  export PATH="${PATH}:${NARGO_HOME}/bin"
  export PATH="${PATH}:~/.bb"
  eval "$(nargo generate-completion-script bash)"
fi

# ~INSTALL_PLATFORMIO
if command -v platformio >/dev/null; then
  # http://docs.platformio.org/en/stable/faq.html#bash-completion
  eval "$(_PLATFORMIO_COMPLETE=source platformio)"
  eval "$(_PIO_COMPLETE=source pio)"
fi

# https://github.com/ajeetdsouza/zoxide#step-2-add-zoxide-to-your-shell
eval "$(zoxide init bash)"

# zoxide: When set to 1, z will print the matched directory before navigating to it.
export _ZO_ECHO=1

# symlink to tinty data-dir baked into the image so it exists upon ~/.local/share/ volume mount
D=~/.local/share/tinted-theming
if [ ! -e ${D}/tinty ]; then
  echo "[xndv] symlinking ~/.tinty -> ${D}/tinty"
  mkdir -p ${D}
  ln -sfn ~/.tinty ${D}/tinty
  tinty apply $(tinty current) # (re)apply current theme for the terminal (kitty)
fi

# symlink aztec home dir so it persists within ~/.local/share/ volume mount
D=~/.local/share/xndv/aztec
if [ ! -e ~/.aztec ]; then
  echo "[xndv] symlinking ~/.aztec -> ${D}"
  mkdir -p ${D}
  ln -sfn ${D} ~/.aztec
fi

# Workaround opencode's re-creation of file(s) that break stow symlinks
F=~/.config/opencode/antigravity-accounts.json && test ! -L ${F} && rm -f ${F}

# ensure files exist for proper stow'ing
D="${XNDV_DIR}/conf.local/.config/opencode" && mkdir -p ${D} && touch ${D}/antigravity-accounts.json # ~INSTALL_OPENCODE
# stow the local conf files
stow \
  --ignore=xndv \
  --target=/home/$(whoami)/ \
  --dir=${XNDV_DIR} \
  conf.local

ls ~/.bash/*.sh &>/dev/null && source ~/.bash/*.sh

# init dir for nvim spell file(s)
spelldir=~/.local/share/nvim/spell
test ! -f ${spelldir} && mkdir -p ${spelldir}

# Workaround issue whereby tmux new window using current pwd does not respect symlinks.
# This reads and applies a file of directory mappings of the format "from:to".
dirmap() {
  F="${XNDV_DIR}/conf.local/xndv/directory_map.txt"
  test -f "${F}" || return
  for line in $(cat "${F}"); do
    from=$(echo "$line" | cut -d':' -f1)
    to=$(echo "$line" | cut -d':' -f2)

    if [[ $PWD =~ ^$from ]]; then
      XNDV_DIRMAP_MSG="[xndv] directory map: $from --> $to"
      XNDV_DIRMAP_PWD=$(echo "$PWD" | sed -e "s|^${from}|${to}|")
      echo ${XNDV_DIRMAP_MSG} && cd ${XNDV_DIRMAP_PWD}
    fi
  done
}
dirmap

# source bash config from mapped volume at run-time
F="${XNDV_DIR}/conf.local/xndv/bash.sh"
test -f ${F} && source ${F}

# source env vars
set -a
source <(sed 's/=\(.*\)/="\1"/' "${XNDV_DIR}/.env")
set +a

# Gateway routing: set ENABLE_GATEWAY=1 in .env to activate
_conf_omo=~/.config/opencode/oh-my-opencode.json
if [[ "${ENABLE_GATEWAY:-0}" == "1" ]]; then
  echo "[xndv] LLM Gateway routing enabled"

  # given a model prefix, get the versioned model name from the opencode config
  get_model() {
    jq -r '
      .provider.litellm.models
      | to_entries
      | map(select(.key | test("^" + $prefix)))
      | .[].key
    ' --arg prefix "${1}" ~/.config/opencode/opencode.json
  }

  export GATEWAY_CLIENT_BASE_URL="${GATEWAY_CLIENT_BASE_URL:-http://${XNDV_HOSTNAME:-localhost}:${GATEWAY_PROXY_PORT}}"
  export GATEWAY_CLIENT_API_KEY="${GATEWAY_CLIENT_API_KEY:-${GATEWAY_MASTER_KEY}}"

  # used by claude code
  export ANTHROPIC_BASE_URL="${GATEWAY_CLIENT_BASE_URL}"
  export ANTHROPIC_AUTH_TOKEN="${GATEWAY_CLIENT_API_KEY}"
  export ANTHROPIC_DEFAULT_OPUS_MODEL=$(get_model claude-opus)
  export ANTHROPIC_DEFAULT_SONNET_MODEL=$(get_model claude-sonnet)
  export ANTHROPIC_DEFAULT_HAIKU_MODEL=$(get_model claude-haiku)

  # configure oh-my-opencode: jsonc overrides .json
  test ! -f "${_conf_omo}.og" &&
    cp "${_conf_omo}" "${_conf_omo}.og" &&
    cat "${_conf_omo}.og" |
    sed -E 's/(anthropic|google|openai)/litellm/' >"${_conf_omo}"
else
  test -f "${_conf_omo}.og" &&
    echo "[xndv] LLM Gateway routing disabled" &&
    cat "${_conf_omo}.og" >"${_conf_omo}" &&
    rm -f "${_conf_omo}.og"
fi

####################################
# drop into fish shell
# - only if the parent process is not fish
# - allow bash commands (bash -c)
# https://wiki.archlinux.org/title/fish#Modify_.bashrc_to_drop_into_fish
####################################

if [[ $(ps --no-header --pid=$PPID --format=comm) != "fish" && -z ${BASH_EXECUTION_STRING} ]]; then
  exec fish
fi

# vim: ft=bash
