#!/usr/bin/env bash
set -euo pipefail

SELECTOR_CHAIN="${XNDV_SELECTOR:-rofi dmenu fzf}"
CONTAINER_PREFIX="xndv"
XNDV_HOST_DATA="${HOME}/.local/share/xndv"
XNDV_USER="xndv"

while [[ $# -gt 0 ]]; do
  case "$1" in
  -s | --selector)
    SELECTOR_CHAIN="$2"
    shift 2
    ;;
  *) break ;;
  esac
done

for s in $SELECTOR_CHAIN; do command -v "$s" &>/dev/null && {
  CONF_SELECTOR="$s"
  break
}; done
[[ -z "${CONF_SELECTOR:-}" ]] && echo "No selector found in: $SELECTOR_CHAIN" >&2 && exit 1

ui() {
  local p="$1" f="${2:-}"
  case "$CONF_SELECTOR" in
  rofi) rofi -dmenu -i -p "$p" -filter "$f" ;;
  dmenu) dmenu -i -p "$p" ;;
  fzf) fzf --prompt "$p> " --reverse --height 40% --query "$f" --print-query | tail -1 || true ;;
  esac
}

# TTY: show command and prompt; GUI: auto-run
confirm_and_run() {
  local label="$1" cmd="$2"
  if [[ -t 0 && -t 1 ]]; then
    echo -e "\n\033[1;32m${label}:\033[0m\n$cmd\n"
    read -rp "Proceed? [Y/n] " confirm
    [[ "${confirm,,}" == "y" || -z "$confirm" ]] && eval "$cmd"
  else
    eval "$cmd"
  fi
}

require_sudo() {
  # Check if stdin (0) is NOT a terminal
  if [ ! -t 0 ]; then
    # rofi -e "Error: This command requires sudo. Please run it from a terminal."
    ui "Error: This command requires sudo. Please run \`$(basename ${0})\` from a terminal."
    exit 1
  fi

  # Ensure sudo credentials are cached upfront — du and rm need root for Docker-owned dirs.
  # Prompt once here so subsequent sudo calls are silent.
  if ! sudo -n true 2>/dev/null; then
    echo "[xndv] sudo required for this command." >&2
    sudo -v || {
      echo "[xndv] sudo authentication failed." >&2
      exit 1
    }
  fi
}

#---------------------------------------------------------------------------
# LAUNCH
#---------------------------------------------------------------------------

# src:[dest]:[tag]:[options]
MOUNTS=(
  "$HOME/.config/git::priv"
  "$HOME/.gnupg::priv"
  "$HOME/.ssh::priv"
  "$HOME/src.priv::priv"
  "$HOME/src::core"
  "$HOME/sshfs::core:rshared"
  "${XNDV_HOST_DATA}:/home/${XNDV_USER}/.local/share:data"
  "${XNDV_HOST_DATA}/xndv/cache:/home/${XNDV_USER}/.cache:data"
  "/media"
  "/mnt"
  "/srv"
)

# Mode Definitions
base() {
  RUNNER="x11docker"
  IMAGE="xen/dev"
  SHELL_CMD="kitty -T"
  ARGS_X11DOCKER=(
    --clipboard
    --dbus
    --gpu
    --hostdisplay
    --network
    --share=/run/dbus/system_bus_socket
    --sudouser
    --user=RETAIN
    --verbose
  )
  ARGS_DOCKER=(
    --add-host=host.docker.internal:host-gateway
    --tmpfs=/tmp:exec
  )
  TAGS=(
    "core"
    "data"
  )
}

mode_max() {
  base
  DESC="Full access, direct GPU acceleration"
  ARGS_X11DOCKER+=(
    --gpu=direct
    --network=host
  )
  ARGS_DOCKER+=(
  )
  TAGS+=(
    "priv"
  )
}

# uses sysbox runtime for docker-in-docker
# persists docker storage in host data volume
# not compatible with x11docker --gpu=direct or --network=host
mode_sys() {
  base
  DESC="Docker-in-Docker via sysbox"
  IMAGE="xen/sys"
  ARGS_X11DOCKER+=(
    --cap-default
    --gpu=virgl
    --runtime=sysbox-runc
    --share=/dev/dri
  )
  ARGS_DOCKER+=(
    --cap-add=NET_ADMIN
    --cap-add=NET_RAW
    --cap-add=SYS_ADMIN
  )
  MOUNTS+=(
    "$HOME/.local/share/xndv/xndv/sysbox/docker:/var/lib/docker:sys"
  )
  TAGS+=(
    "sys"
  )
}

mode_min() {
  base
  DESC="Minimal host access, max isolation"
  ARGS_X11DOCKER=(
    --gpu
    --hostdisplay
    --network
    --user=RETAIN
    --verbose
  )
  TAGS+=()
}

mode_tty() {
  DESC="TTY-only, no X11"
  RUNNER="docker"
  IMAGE="xen/dev"
  SHELL_CMD="/bin/bash -l"
  ARGS_DOCKER=(
    --add-host=host.docker.internal:host-gateway
    --network=host
    --tmpfs=/tmp:exec
  )
  TAGS=("core")
}

cmd_launch() {
  #---------------------------------------------------------------------------
  # 1. Action Selection — attach to existing container or create new instance
  #---------------------------------------------------------------------------
  mapfile -t options < <(
    echo "+ New Instance"
    docker ps --filter "name=^${CONTAINER_PREFIX}-" --format '{{.Names}} │ {{.Label "xndv.mode"}}' 2>/dev/null || true
  )
  sel=$(ui "xndv" <<<"$(printf '%s\n' "${options[@]}")")
  [[ -z "$sel" ]] && exit 0
  [[ "$sel" != "+ New Instance" ]] && { exec docker exec -it "${sel%% *}" /bin/bash; }

  #---------------------------------------------------------------------------
  # 2. Mode Selection — choose environment preset (max, min, sys, tty)
  #---------------------------------------------------------------------------
  modes=($(declare -F | grep "mode_" | cut -d_ -f2-))
  m_sel=$(ui "Mode" <<<"$(for m in "${modes[@]}"; do (
    "mode_$m"
    printf "%-10s │ %s\n" "$m" "$DESC"
  ); done)")
  [[ -z "$m_sel" ]] && exit 0
  mode="${m_sel%% *}"

  #---------------------------------------------------------------------------
  # 3. Container Name — pre-filled with mode-based default
  #---------------------------------------------------------------------------
  inst=$(ui "Container Name" "${CONTAINER_PREFIX}-$mode-" <<<"")
  [[ -z "$inst" ]] && inst="${CONTAINER_PREFIX}-$mode"

  #---------------------------------------------------------------------------
  # 4. Mount Selection — toggle volume mounts before launching
  #---------------------------------------------------------------------------
  "mode_$mode"
  declare -A selected
  for i in "${!MOUNTS[@]}"; do
    IFS=':' read -r src dst tag opts <<<"${MOUNTS[$i]}"
    for dt in "${TAGS[@]:-}"; do
      [[ -n "$tag" && "$tag" == "$dt" ]] && selected[$i]=1
    done
  done

  while true; do
    menu_lines=("▶ LAUNCH")
    for i in "${!MOUNTS[@]}"; do
      state="[ ]"
      [[ -n "${selected[$i]:-}" ]] && state="[x]"
      IFS=':' read -r src dst tag opts <<<"${MOUNTS[$i]}"
      printf -v line "%s %-40s%s" "$state" "$src" "${tag:+ │ :$tag}"
      menu_lines+=("$line")
    done

    choice=$(ui "Mounts" <<<"$(printf '%s\n' "${menu_lines[@]}")")

    [[ -z "$choice" ]] && exit 0
    [[ "$choice" == "▶ LAUNCH" ]] && break

    choice_path=$(echo "$choice" | sed 's/^\[.\] //; s/  *│.*//; s/ *$//')
    for i in "${!MOUNTS[@]}"; do
      IFS=':' read -r src dst tag opts <<<"${MOUNTS[$i]}"
      if [[ "$src" == "$choice_path" ]]; then
        if [[ -n "${selected[$i]:-}" ]]; then unset "selected[$i]"; else selected[$i]=1; fi
        break
      fi
    done
  done

  #---------------------------------------------------------------------------
  # 5. Build Command & Confirm Launch
  #---------------------------------------------------------------------------
  vol_args=()
  for i in "${!selected[@]}"; do
    IFS=':' read -r src dst tag opts <<<"${MOUNTS[$i]}"
    dst="${dst:-/home/${XNDV_USER}/${src#$HOME/}}"
    [[ ! -d "$src" ]] && mkdir -p "$src"
    vol_args+=("--volume" "$src:$dst${opts:+:$opts}")
  done

  "mode_$mode"
  ARGS_DOCKER+=(--label xndv.mode=$mode)
  [[ "$RUNNER" == "x11docker" ]] &&
    cmd="x11docker --name $inst ${ARGS_X11DOCKER[*]} -- ${ARGS_DOCKER[*]} ${vol_args[*]} -- $IMAGE $SHELL_CMD $inst" ||
    cmd="docker run -it --rm --name $inst ${ARGS_DOCKER[*]} ${vol_args[*]} $IMAGE $SHELL_CMD"

  confirm_and_run "Generated Command" "$cmd"
}

#---------------------------------------------------------------------------
# CLEAN
#---------------------------------------------------------------------------

# Host-persistent data dirs for selective cleanup
# Format: tag:path:label
#   cache — safe to delete; data is auto-regenerated (binaries, analytics, caches)
#   state — active config or auth; deletion causes friction (re-login, reconfiguration)
DIRS=(
  "cache:${XNDV_HOST_DATA}/xndv/ai/gateway/postgres:LiteLLM Postgres"
  "cache:${XNDV_HOST_DATA}/xndv/ai/gateway/redis:LiteLLM Redis"
  "cache:${XNDV_HOST_DATA}/xndv/ai/open-webui:Open WebUI data"
  "cache:${XNDV_HOST_DATA}/xndv/aztec:Aztec versioned binaries"
  "cache:${XNDV_HOST_DATA}/xndv/cache:Container ~/.cache"
  "cache:${XNDV_HOST_DATA}/xndv/mcp/aztec:Aztec MCP server data"
  "cache:${XNDV_HOST_DATA}/xndv/mcp/noir:Noir MCP repos"
  "cache:${XNDV_HOST_DATA}/xndv/sysbox/docker:Sysbox /var/lib/docker storage"
  "state:${XNDV_HOST_DATA}/xndv/ai/gateway/cliproxyapi-auth:OAuth tokens (re-login required)"
)

cmd_clean() {
  require_sudo

  if [[ ! -d "$XNDV_HOST_DATA" ]]; then
    echo "[xndv] Data directory not found: $XNDV_HOST_DATA" >&2
    exit 1
  fi

  #---------------------------------------------------------------------------
  # 1. Measure disk usage — cache entries sorted by size desc, state at bottom
  #---------------------------------------------------------------------------
  # Build a sorted index into DIRS: cache entries (size desc) then state entries
  local cache_idx=() state_idx=() sorted_idx=()
  local sizes=()
  for i in "${!DIRS[@]}"; do
    IFS=':' read -r tag path label <<<"${DIRS[$i]}"
    local size="-"
    [[ -d "$path" ]] && size=$(sudo du -sh "$path" 2>/dev/null | cut -f1)
    sizes[$i]="$size"
    [[ "$tag" == "state" ]] && state_idx+=("$i") || cache_idx+=("$i")
  done

  # Sort cache indices by size descending
  local cache_sorted
  mapfile -t cache_sorted < <(
    for i in "${cache_idx[@]}"; do printf '%s %s\n' "${sizes[$i]}" "$i"; done |
      sort -k1 -h -r | awk '{print $2}'
  )
  sorted_idx=("${cache_sorted[@]}" "${state_idx[@]}")

  #---------------------------------------------------------------------------
  # 2. Directory Selection — toggle dirs to delete, confirm with ▶ CLEAN
  #---------------------------------------------------------------------------
  declare -A selected
  while true; do
    local menu_lines=("▶ CLEAN")
    for i in "${sorted_idx[@]}"; do
      IFS=':' read -r tag path label <<<"${DIRS[$i]}"
      local chk="[ ]"
      [[ -n "${selected[$i]:-}" ]] && chk="[x]"
      local rel="${path#"${XNDV_HOST_DATA}/"}"
      local line
      printf -v line "%s %-5s  %6s  %-46s %s" "$chk" "$tag" "${sizes[$i]}" "$rel" "$label"
      menu_lines+=("$line")
    done

    local choice
    choice=$(ui "Clean" <<<"$(printf '%s\n' "${menu_lines[@]}")")

    [[ -z "$choice" ]] && exit 0
    [[ "$choice" == "▶ CLEAN" ]] && break

    # Toggle selection by stripping checkbox prefix then extracting relpath (field 3)
    local choice_rel
    choice_rel=$(sed 's/^\[.\] //' <<<"$choice" | awk '{print $3}')
    for i in "${sorted_idx[@]}"; do
      IFS=':' read -r tag path label <<<"${DIRS[$i]}"
      local rel="${path#"${XNDV_HOST_DATA}/"}"
      if [[ "$rel" == "$choice_rel" ]]; then
        if [[ -n "${selected[$i]:-}" ]]; then unset "selected[$i]"; else selected[$i]=1; fi
        break
      fi
    done
  done

  local selected_paths=() selected_state_paths=()
  for i in "${!selected[@]}"; do
    IFS=':' read -r tag path label <<<"${DIRS[$i]}"
    selected_paths+=("$path")
    [[ "$tag" == "state" ]] && selected_state_paths+=("$path")
  done

  [[ ${#selected_paths[@]} -eq 0 ]] && exit 0

  #---------------------------------------------------------------------------
  # 3. State Warning — extra TTY confirmation for auth/config directories
  #---------------------------------------------------------------------------
  if [[ ${#selected_state_paths[@]} -gt 0 ]]; then
    echo ""
    echo "[xndv] WARNING: the following require re-login or reconfiguration after deletion:"
    for p in "${selected_state_paths[@]}"; do
      echo "  [state]  $p"
    done
    echo ""
    read -rp "Type YES to confirm deletion of state directories: " confirm_state
    [[ "$confirm_state" != "YES" ]] && echo "[xndv] Cancelled." >&2 && exit 0
  fi

  #---------------------------------------------------------------------------
  # 4. Build Command & Confirm Deletion
  #---------------------------------------------------------------------------
  local total_freed
  total_freed=$(sudo du -shc "${selected_paths[@]}" 2>/dev/null | tail -1 | cut -f1)
  local n="${#selected_paths[@]}" noun
  [[ "$n" -eq 1 ]] && noun="directory" || noun="directories"

  local cmd="sudo rm -rf $(printf '"%s" ' "${selected_paths[@]}")"
  echo ""
  echo "[xndv] Will delete ${n} ${noun} (~${total_freed}):"
  for p in "${selected_paths[@]}"; do echo "  $p"; done

  confirm_and_run "Delete Command" "$cmd"
}

#---------------------------------------------------------------------------
# MAIN
#---------------------------------------------------------------------------

main() {
  cmds=($(declare -F | sort -r | grep " cmd_" | sed 's/.* cmd_//'))
  c_sel=$(ui "xndv" <<<"$(printf '%s\n' "${cmds[@]}")")
  [[ -z "$c_sel" ]] && exit 0
  "cmd_${c_sel}"
}

main
